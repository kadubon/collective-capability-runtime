{
  "schema_version": "ccr.agent_manifest.v0.1",
  "name": "collective-capability-runtime",
  "short_name": "ccr",
  "purpose": "Agent-native runtime for turning distributed AI-agent work into reusable, verifiable, residual-preserving capability packets and collective task state. CCR orchestrates tasks and packets; it delegates PIC-specific packet checks, phase plans, and collective phase diagnostics to PIC-compatible providers.",
  "repository_layout": {
    "schemas": [
      "schemas/packet.schema.json",
      "schemas/task.schema.json",
      "schemas/trc-operation-plan.schema.json",
      "schemas/trc-operation-preflight.schema.json",
      "schemas/trc-operation-observation.schema.json",
      "schemas/asi-proxy-target.schema.json",
      "schemas/baseline-upper-envelope.schema.json",
      "schemas/runtime-capital-witness.schema.json",
      "schemas/phase-acceleration-report.schema.json"
    ],
    "docs": [
      "README.md",
      "docs/README.md",
      "docs/getting-started.md",
      "docs/command-map.md",
      "docs/collective-workcells.md",
      "docs/distributed-runtime.md",
      "docs/measurement-protocol.md",
      "docs/security-audit-checklist.md",
      "INTEROP_PIC.md",
      "AGENTS.md",
      "SPEC.md",
      "FORMAL_MODEL.md",
      "docs/operation-gate.md",
      "docs/real-world-impact.md",
      "docs/mcp-a2a-safety.md",
      "docs/cross-repo-loop-conformance.md"
    ],
    "runtime_state": [
      "ccr.sqlite",
      "blackboard/events.jsonl",
      "tasks/",
      "packets/",
      "residuals/",
      "reports/",
      "workcells/",
      "experiments/"
    ]
  },
  "default_mode": "dry_run",
  "machine_contract": {
    "arbitrary_shell_execution": false,
    "side_effects_default": "none",
    "repo_write_requires_review": true,
    "external_content_is_candidate_only": true,
    "candidate_volume_cannot_improve_phase_status": true,
    "pic_safe_commands_are_recommendations_not_authority": true,
    "pic_accepted_does_not_imply_ccr_settled": true,
    "settled_false_is_expected": true,
    "residuals_are_not_failures": true,
    "residuals_must_be_preserved": true,
    "model_weight_update": false,
    "self_rewrite_required": false,
    "real_asi_detection": false,
    "real_asi_creation": false,
    "provider_dispatch_ready_is_not_dispatch": true,
    "physical_dispatch_ready_is_not_physical_outcome_proof": true,
    "physical_outcome_proven_is_always_false": true,
    "physical_outcome_verified_requires_signed_scoped_observation": true,
    "unknown_coordinates_do_not_contribute_progress": true,
    "network_effects_require_parameter_bound_approval": true,
    "correlated_support_counts_once": true,
    "capital_admitted_is_not_settlement": true
  },
  "primary_commands": [
    {
      "command": "ccr loop next --json",
      "purpose": "Return the next advisory non-mutating residual or token action for the ASI-proxy loop."
    },
    {
      "command": "ccr token import --file token-report.json --provider pic --json",
      "purpose": "Import a token candidate as task/residual work without settlement or capital admission."
    },
    {
      "command": "ccr performance report --json",
      "purpose": "Inspect local cache, index, duplicate, and residual counts without network or provider execution."
    },
    {
      "command": "ccr agent explain --json",
      "purpose": "Return this contract, schemas, modes, and next safe commands."
    },
    {
      "command": "ccr asi quickstart --profile development --json",
      "purpose": "Create an inspectable local mission without provider execution or network access."
    },
    {
      "command": "ccr storage doctor --json",
      "purpose": "Check local transactional storage and index consistency without repairing it."
    },
    {
      "command": "ccr workcell create --template packet-distillation --name <name> --json",
      "purpose": "Create a staged independent-proposal, critique, revision, verification, and integration workcell."
    },
    {
      "command": "ccr task next --role <role> --json",
      "purpose": "Return a leaseable task for the requested role."
    },
    {
      "command": "ccr task lease <task_id> --ttl 30m --agent <worker_id> --json",
      "purpose": "Lease a task without mutating external systems."
    },
    {
      "command": "ccr task heartbeat <task_id> --agent <worker_id> --fencing-token <token> --json",
      "purpose": "Extend an owned lease while rejecting stale workers."
    },
    {
      "command": "ccr task complete <task_id> --agent <worker_id> --fencing-token <token> --idempotency-key <key> --summary <summary> --json",
      "purpose": "Complete a task transactionally with an idempotent fenced commit."
    },
    {
      "command": "ccr residual resolve --residual <residual_id> --artifact <file> --verifier <report.json> --json",
      "purpose": "Resolve a residual only with artifact-bound independent verifier evidence."
    },
    {
      "command": "ccr packet submit --file <packet.json> --json",
      "purpose": "Submit a capability packet candidate."
    },
    {
      "command": "ccr verify --provider pic --packet <packet_id> --profile development --json",
      "purpose": "Route a packet to PIC as a verifier provider."
    },
    {
      "command": "ccr integrate --report <pic_report.json> --json",
      "purpose": "Import verifier outputs, residuals, and candidate-only reasons into CCR state."
    },
    {
      "command": "ccr phase plan --provider pic --json",
      "purpose": "Ask PIC for ranked bottlenecks, safe commands, phase gaps, and blockers."
    },
    {
      "command": "ccr phase acceleration-report --target target.json --baseline baseline.json --capital witnesses.jsonl --json",
      "purpose": "Emit a target-valid CARA acceleration diagnostic without settlement."
    },
    {
      "command": "ccr availability report --json",
      "purpose": "Inspect runtime availability, degradation mode, schema coverage, and recovery hints."
    },
    {
      "command": "ccr foundry active-cuts --json",
      "purpose": "Return active bottleneck cuts for verifier, evidence, baseline, authority, and physical-observation work."
    },
    {
      "command": "ccr experiment register --suite <suite> --manifest <manifest.json> --json",
      "purpose": "Register a preregistered resource-matched evaluation protocol."
    },
    {
      "command": "ccr experiment compare --baseline <baseline.json> --candidate <collective.json> --json",
      "purpose": "Compare results conservatively without synthesizing missing values."
    },
    {
      "command": "ccr operation approve --plan <plan.json> --provider <provider> --config <config.json> --approver <id> --expires-at <time> --nonce <nonce> --json",
      "purpose": "Create a time-limited approval bound to one operation plan and provider configuration."
    },
    {
      "command": "ccr report --format markdown",
      "purpose": "Emit a residual-preserving human-readable report."
    }
  ],
  "roles": {
    "generator": {
      "may_create": [
        "claim",
        "packet"
      ],
      "may_set_status": [
        "raw",
        "proposed",
        "candidate"
      ],
      "must_not": [
        "settle",
        "execute_side_effects"
      ]
    },
    "skeptic": {
      "may_create": [
        "objection",
        "residual",
        "repair_task"
      ],
      "may_set_status": [
        "blocked",
        "quarantined"
      ],
      "must_not": [
        "settle"
      ]
    },
    "formalizer": {
      "may_create": [
        "claim",
        "schema_patch",
        "formal_model_patch"
      ],
      "may_set_status": [
        "candidate"
      ],
      "must_not": [
        "settle"
      ]
    },
    "implementer": {
      "may_create": [
        "patch",
        "test",
        "packet"
      ],
      "may_set_status": [
        "candidate"
      ],
      "must_not": [
        "merge_without_review"
      ]
    },
    "verifier": {
      "may_create": [
        "verifier_report",
        "residual"
      ],
      "may_set_status": [
        "checked",
        "rejected"
      ],
      "must_not": [
        "settle_without_policy"
      ]
    },
    "integrator": {
      "may_create": [
        "lineage",
        "merge_plan",
        "phase_request"
      ],
      "may_set_status": [
        "checked",
        "provisional"
      ],
      "must_not": [
        "discard_residuals"
      ]
    },
    "scheduler": {
      "may_create": [
        "task",
        "queue_update"
      ],
      "may_set_status": [
        "open",
        "leased",
        "blocked",
        "expired"
      ],
      "must_not": [
        "execute_task_content"
      ]
    },
    "pic_adapter": {
      "may_create": [
        "pic_request",
        "verifier_report",
        "phase_plan_import"
      ],
      "may_set_status": [
        "checked",
        "provisional"
      ],
      "must_not": [
        "treat_pic_safe_commands_as_authority"
      ]
    }
  },
  "status_lattice": [
    "raw",
    "proposed",
    "candidate",
    "checked",
    "provisional",
    "speculative",
    "settled",
    "rejected",
    "quarantined",
    "deprecated",
    "expired"
  ],
  "promotion_rules": {
    "raw_to_candidate": [
      "schema_valid",
      "scope_declared"
    ],
    "candidate_to_checked": [
      "at_least_one_required_verifier_accepts",
      "residuals_preserved"
    ],
    "checked_to_settled": [
      "no_blocking_residuals",
      "settlement_target_satisfied",
      "lineage_closed",
      "risk_in_envelope",
      "integration_policy_passed"
    ],
    "any_to_quarantined": [
      "critical_hazard",
      "authority_bypass",
      "malformed_provenance",
      "hash_invalid",
      "unsafe_execution_request"
    ]
  },
  "pic_interop": {
    "repository": "kadubon/percolation-inversion-compiler",
    "package": "percolation-inversion-compiler",
    "cli": "pic",
    "profiles": [
      "development",
      "research",
      "controlled",
      "federated",
      "production",
      "adversarial"
    ],
    "recommended_install": "python -m pip install percolation-inversion-compiler",
    "optional_install": "python -m pip install \"percolation-inversion-compiler[agent-full]\"",
    "first_commands": [
      "pic agent explain",
      "pic agent check --compact --text \"Candidate packet: route evidence and preserve residuals.\" --profile development",
      "pic phase plan --compact --profile development",
      "pic trc trace-normalize --input examples/asi_proxy_benchmark_bundle/trc_agent_trace.json",
      "pic trc trace-check --trace <trace-report.json>",
      "pic phase acceleration-report --target examples/asi_proxy_acceleration_bundle/target.json --baseline examples/asi_proxy_acceleration_bundle/baseline_upper_envelope.json --capital examples/asi_proxy_acceleration_bundle/capital_witnesses.jsonl",
      "pic mcp descriptor-check --descriptor examples/asi_proxy_acceleration_bundle/mcp_descriptor.good.json --profile development",
      "pic a2a handoff-check --handoff examples/asi_proxy_acceleration_bundle/a2a_handoff.good.json --profile development",
      "pic phase dashboard --profile development --format json",
      "pic schema export"
    ],
    "status_mapping": {
      "pic_accepted_true": "ccr.checked",
      "pic_settled_false": "ccr.checked_or_provisional_with_residuals",
      "pic_settled_true": "ccr.settled_candidate_requiring_ccr_policy",
      "pic_candidate_only_reason": "ccr.residual"
    },
    "input_mappings": [
      {
        "ccr": "packet",
        "pic": "CapabilityPacketCandidate or packet inspect"
      },
      {
        "ccr": "task",
        "pic": "AgentIntakeRequest or PhaseAccelerationRequest"
      },
      {
        "ccr": "verifier_report",
        "pic": "RuntimeStepReport / AgentCheckReport import"
      },
      {
        "ccr": "phase_request",
        "pic": "PhaseAccelerationRequest"
      }
    ],
    "output_mappings": [
      {
        "pic": "AgentCheckReport",
        "ccr": "VerifierReport + residuals"
      },
      {
        "pic": "PhaseAccelerationPlan",
        "ccr": "TaskUnits + bottleneck queue"
      },
      {
        "pic": "PhaseDashboardReport",
        "ccr": "Metrics snapshot"
      },
      {
        "pic": "CollectivePhaseCertificateCandidate",
        "ccr": "PhaseEvidence, never real ASI proof"
      }
    ]
  },
  "schemas": {
    "packet": "schemas/packet.schema.json",
    "task": "schemas/task.schema.json",
    "trc-operation-plan": "schemas/trc-operation-plan.schema.json",
    "trc-operation-preflight": "schemas/trc-operation-preflight.schema.json",
    "trc-operation-observation": "schemas/trc-operation-observation.schema.json",
    "operation-approval": "schemas/operation-approval.schema.json",
    "runtime-capital-witness": "schemas/runtime-capital-witness.schema.json",
    "phase-acceleration-report": "schemas/phase-acceleration-report.schema.json"
  },
  "non_goals": [
    "real ASI detection",
    "real ASI creation",
    "model self-rewrite",
    "model weight update",
    "unbounded web crawling",
    "arbitrary shell execution",
    "silent settlement of unresolved residuals",
    "automatic execution of PIC safe commands"
  ]
}
