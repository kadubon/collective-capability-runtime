  "required": ["schema_version", "ok", "opened", "resolved", "unchanged", "newly_blocking", "no_longer_blocking", "severity_delta", "residual_debt_delta", "by_kind_delta", "added_residual_ids", "removed_residual_ids", "unchanged_residual_ids", "external_execution", "network_call_performed", "settled", "non_claims"],
