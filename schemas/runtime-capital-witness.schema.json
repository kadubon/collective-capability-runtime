{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kadubon.github.io/collective-capability-runtime/schemas/runtime-capital-witness.schema.json",
  "title": "CCR Runtime Capital Witness",
  "type": "object",
  "required": [
    "schema_version",
    "witness_id",
    "coordinate",
    "packet_refs",
    "capital_lower_bound",
    "cost_upper_bound",
    "hazard_charge_upper_bound",
    "transport_charge_upper_bound",
    "signed_surplus_lower_bound",
    "value_estimand_type",
    "mission_valid",
    "transport_valid",
    "finality_valid",
    "hazard_constrained",
    "gauge_compatible",
    "raw_net_solvent",
    "capital_admitted",
    "residuals",
    "blockers",
    "settled"
  ],
  "properties": {
    "schema_version": { "const": "ccr.runtime_capital_witness.v1" },
    "value_estimand_type": { "enum": ["causal", "calibrated_proxy", "proxy_only"] },
    "capital_admitted": { "type": "boolean" },
    "settled": { "const": false },
    "residuals": { "type": "array", "items": { "type": "object" } },
    "blockers": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
