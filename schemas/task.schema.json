{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kadubon.github.io/collective-capability-runtime/schemas/task.schema.json",
  "title": "CCR Task Unit",
  "description": "Agent-native task schema for leasing, executing, verifying, and preserving residual work in Collective Capability Runtime. Designed to route work to PIC without granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "created_at",
    "status",
    "role",
    "title",
    "objective",
    "inputs",
    "expected_outputs",
    "constraints",
    "lease",
    "verifier_plan",
    "residual_policy",
    "pic_interop"
  ],
  "properties": {
    "schema_version": {
      "const": "ccr.task.v0.1"
    },
    "task_id": {
      "$ref": "#/$defs/id"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "leased",
        "submitted",
        "blocked",
        "verified",
        "integrated",
        "quarantined",
        "rejected",
        "expired"
      ]
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 50
    },
    "role": {
      "type": "string",
      "enum": [
        "generator",
        "skeptic",
        "formalizer",
        "implementer",
        "verifier",
        "integrator",
        "librarian",
        "scheduler",
        "security_reviewer",
        "pic_adapter",
        "benchmark_runner"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_ref"
      },
      "default": []
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/expected_output"
      }
    },
    "constraints": {
      "$ref": "#/$defs/constraints"
    },
    "lease": {
      "$ref": "#/$defs/lease"
    },
    "verifier_plan": {
      "$ref": "#/$defs/verifier_plan"
    },
    "residual_policy": {
      "$ref": "#/$defs/residual_policy"
    },
    "pic_interop": {
      "$ref": "#/$defs/pic_interop"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "default": []
    },
    "blackboard_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "submitted_at": {
          "type": "string",
          "format": "date-time"
        },
        "submitted_by": {
          "type": "string"
        },
        "output_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        },
        "residuals_added": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        }
      },
      "default": {}
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^x_[A-Za-z0-9_.-]+$"
      },
      "additionalProperties": true,
      "default": {}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:/@+-]{2,127}$"
    },
    "input_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "kind"
      ],
      "properties": {
        "ref": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "packet",
            "claim",
            "artifact",
            "blackboard_event",
            "residual",
            "report",
            "url",
            "text",
            "file",
            "other"
          ]
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "expected_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schema_ref",
        "destination"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "packet",
            "claim",
            "patch",
            "verifier_report",
            "residual",
            "phase_request",
            "phase_plan",
            "benchmark_report",
            "markdown",
            "json",
            "other"
          ]
        },
        "schema_ref": {
          "type": "string"
        },
        "destination": {
          "type": "string"
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "side_effect_policy",
        "network_policy",
        "authority_policy",
        "max_runtime_minutes"
      ],
      "properties": {
        "side_effect_policy": {
          "type": "string",
          "enum": [
            "none",
            "dry_run_only",
            "sandbox_only",
            "operator_approval_required"
          ]
        },
        "network_policy": {
          "type": "string",
          "enum": [
            "none",
            "explicit_source_only",
            "bounded_live_connectors",
            "unrestricted_not_allowed"
          ]
        },
        "authority_policy": {
          "type": "string",
          "enum": [
            "read_only",
            "local_write",
            "repo_write_requires_review",
            "external_side_effects_forbidden"
          ]
        },
        "max_runtime_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440
        },
        "forbidden_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "allowed_commands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lease_required",
        "ttl_minutes"
      ],
      "properties": {
        "lease_required": {
          "type": "boolean"
        },
        "leased_by": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "leased_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "ttl_minutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440
        },
        "renewal_allowed": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "verifier_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_verifiers",
        "promotion_gate"
      ],
      "properties": {
        "required_verifiers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "optional_verifiers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "promotion_gate": {
          "type": "string",
          "enum": [
            "none",
            "schema_only",
            "pic_checked",
            "pic_checked_plus_human_review",
            "integration_tests",
            "custom"
          ]
        },
        "failure_route": {
          "type": "string",
          "enum": [
            "residual",
            "repair_task",
            "quarantine",
            "reject"
          ],
          "default": "residual"
        }
      }
    },
    "residual_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserve_residuals",
        "blocking_residuals_prevent_settlement"
      ],
      "properties": {
        "preserve_residuals": {
          "type": "boolean"
        },
        "blocking_residuals_prevent_settlement": {
          "type": "boolean"
        },
        "residual_destination": {
          "type": "string"
        },
        "minimum_residual_fields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "residual_id",
            "kind",
            "description",
            "blocking"
          ]
        }
      }
    },
    "pic_interop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "recommended_pic_commands",
        "pic_profile",
        "candidate_only_until_checked"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "pic_profile": {
          "type": "string",
          "enum": [
            "development",
            "research",
            "controlled",
            "federated",
            "production",
            "adversarial"
          ]
        },
        "candidate_only_until_checked": {
          "type": "boolean"
        },
        "recommended_pic_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input_mapping": {
          "type": "string",
          "enum": [
            "text_to_agent_check",
            "packet_to_packet_inspect",
            "report_to_phase_plan",
            "report_to_phase_lab",
            "alt_admission",
            "agent_message",
            "none"
          ]
        },
        "identity_context_required": {
          "type": "boolean",
          "default": false
        },
        "output_mapping": {
          "type": "string",
          "enum": [
            "pic_report_to_verifier_report",
            "pic_phase_plan_to_tasks",
            "pic_dashboard_to_metrics",
            "pic_residuals_to_residual_ledger",
            "none"
          ]
        }
      }
    }
  }
}
