{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kadubon.github.io/collective-capability-runtime/schemas/workbench-report.schema.json",
  "title": "CCR Workbench Report",
  "type": "object",
  "required": [
    "schema_version",
    "mission_id",
    "profile",
    "ok",
    "accepted",
    "settled",
    "network_call_performed",
    "positive_packet_count",
    "candidate_only_count",
    "blocking_residual_count",
    "top_residuals",
    "next_safe_action",
    "non_claims"
  ],
  "properties": {
    "schema_version": { "const": "ccr.workbench_report.v1" },
    "mission_id": { "type": "string" },
    "profile": { "type": ["string", "null"] },
    "ok": { "type": "boolean" },
    "accepted": { "type": "boolean" },
    "settled": { "const": false },
    "external_execution": { "const": false },
    "network_call_performed": { "const": false },
    "mutated_runtime": { "const": false },
    "positive_packet_count": { "type": "integer", "minimum": 0 },
    "candidate_only_count": { "type": "integer", "minimum": 0 },
    "blocking_residual_count": { "type": "integer", "minimum": 0 },
    "top_residuals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["residual_id", "kind", "description", "blocking"],
        "properties": {
          "residual_id": { "type": "string" },
          "kind": { "type": "string" },
          "finding_kind": { "type": "string" },
          "description": { "type": "string" },
          "blocking": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "next_safe_action": {
      "type": "object",
      "required": ["external_execution", "writes_runtime"],
      "properties": {
        "command": { "type": "string" },
        "external_execution": { "const": false },
        "writes_runtime": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "packet_status_summary": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "non_claims": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": true
}
