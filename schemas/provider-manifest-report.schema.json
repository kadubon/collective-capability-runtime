{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kadubon.github.io/collective-capability-runtime/schemas/provider-manifest-report.schema.json",
  "title": "CCR Provider Manifest Report",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "accepted",
    "provider_id",
    "manifest_hash",
    "blockers",
    "residuals",
    "non_claims",
    "external_execution",
    "network_call_performed",
    "settled"
  ],
  "properties": {
    "schema_version": { "const": "ccr.provider_manifest_report.v1" },
    "ok": { "type": "boolean" },
    "accepted": { "type": "boolean" },
    "provider_id": { "type": "string" },
    "manifest_hash": { "type": "string" },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "residuals": { "type": "array", "items": { "type": "object" } },
    "non_claims": { "type": "array", "items": { "type": "string" } },
    "external_execution": { "const": false },
    "network_call_performed": { "const": false },
    "settled": { "const": false }
  },
  "additionalProperties": true
}
